<+><!--\r\n    reserva.xhtml — página de Reserva\r\n    ═══════════════════════════════════════════════════════════\r\n    Contrato esperado de ReservaBean:\r\n      - String   selectedCourtId               -> bindeado desde f:viewParam \"courtId\"\r\n      - Court    getActiveCourt()               -> name, surface, pricePerHour,\r\n                                                    hasLighting, isCovered, imageUrl,\r\n                                                    type.label / type.emoji / type.icon\r\n      - String   date / hour                    -> get/set\r\n      - int      duration / playerCount         -> get/set\r\n      - String   contactName / contactPhone     -> get/set (autorellenado en @PostConstruct\r\n                                                    desde authBean.currentUser si está logueado)\r\n      - String[] getAvailableHours()\r\n      - double   getTotalPrice() / getPricePerPlayer()\r\n      - String   doReserve()                    -> action, agrega FacesMessage si falla\r\n\r\n    Contrato esperado de AuthBean:\r\n      - boolean  isAuthenticated()\r\n      - void     openLogin()\r\n\r\n    Contrato esperado de CourtService (bean @Named ya disponible por CDI):\r\n      - List<TimeSlot> getSchedule(String courtId, String date) -> hour, available\r\n-->\r\n<ui:composition template=\"WEB-INF/templates/fragments/layout.xhtml\"\r\n                xmlns=\"http://www.w3.org/1999/xhtml\"\r\n                xmlns:h=\"jakarta.faces.html\"\r\n                xmlns:f=\"jakarta.faces.core\"\r\n                xmlns:ui=\"jakarta.faces.facelets\"\r\n                xmlns:p=\"primefaces\">\r\n\r\n    <f:metadata>\r\n        <f:viewParam name=\"courtId\" value=\"#{reservaBean.selectedCourtId}\"/>\r\n    </f:metadata>\r\n\r\n    <ui:define name=\"title\">Hacer una Reserva</ui:define>\r\n\r\n    <ui:define name=\"content\">\r\n\r\n        <div class=\"fp-page-header\">\r\n            <div class=\"fp-page-header-title\">\r\n                <span class=\"material-symbols-outlined\">calendar_add_on</span>\r\n                <h1>Hacer una Reserva</h1>\r\n            </div>\r\n            <p>Revisa la disponibilidad de la cancha y completa tus datos. El sistema calculará el precio automáticamente.</p>\r\n        </div>\r\n\r\n        <!-- ═══ SIN CANCHA SELECCIONADA ═══ -->\r\n        <h:panelGroup rendered=\"#{empty reservaBean.activeCourt}\" layout=\"block\" styleClass=\"fp-text-center\" style=\"padding:4rem 1rem 6rem;\">\r\n            <span class=\"material-symbols-outlined\" style=\"font-size:4rem;color:var(--fp-text-muted);opacity:.25;\">sports_soccer</span>\r\n            <h2 style=\"font-family:'DM Sans',sans-serif;font-weight:700;font-size:1.375rem;color:var(--fp-text);margin:1rem 0 .5rem;\">Selecciona una cancha primero</h2>\r\n            <p style=\"color:var(--fp-text-secondary);margin-bottom:1.5rem;\">Elige una cancha desde Horarios para continuar con tu reserva.</p>\r\n            <h:link outcome=\"/horarios\" styleClass=\"fp-btn fp-btn-primary\">\r\n                <span class=\"material-symbols-outlined\" style=\"font-size:1.125rem;\">event</span>\r\n                Ver Horarios\r\n            </h:link>\r\n        </h:panelGroup>\r\n\r\n        <!-- ═══ FLUJO DE RESERVA ═══ -->\r\n        <h:panelGroup rendered=\"#{not empty reservaBean.activeCourt}\" layout=\"block\">\r\n            <div class=\"fp-reserva-grid\">\r\n\r\n                <!-- ═══ COLUMNA IZQUIERDA: cancha + horarios ═══ -->\r\n                <div>\r\n                    <div class=\"fp-card\" style=\"overflow:hidden;\">\r\n                        <div class=\"fp-court-photo\">\r\n                            <h:graphicImage value=\"#{reservaBean.activeCourt.imageUrl}\"\r\n                                            rendered=\"#{not empty reservaBean.activeCourt.imageUrl}\"\r\n                                            style=\"width:100%;height:100%;object-fit:cover;\"/>\r\n                            <h:panelGroup rendered=\"#{empty reservaBean.activeCourt.imageUrl}\" layout=\"block\" styleClass=\"fp-court-photo-placeholder\">\r\n                                #{reservaBean.activeCourt.type.emoji}\r\n                            </h:panelGroup>\r\n                            <span class=\"fp-chip\" style=\"position:absolute;top:1rem;left:1rem;background:var(--fp-bg-card);\">\r\n                                <span class=\"material-symbols-outlined\" style=\"font-size:1rem;\">#{reservaBean.activeCourt.type.icon}</span>\r\n                                #{reservaBean.activeCourt.type.label}\r\n                            </span>\r\n                            <h:link outcome=\"/horarios\" styleClass=\"fp-chip\" style=\"position:absolute;top:1rem;right:1rem;background:var(--fp-bg-card);text-decoration:none;\">\r\n                                <span class=\"material-symbols-outlined\" style=\"font-size:1rem;\">swap_horiz</span> Cambiar\r\n                            </h:link>\r\n                        </div>\r\n\r\n                        <div style=\"padding:1.5rem;\">\r\n                            <h3 style=\"font-family:'DM Sans',sans-serif;font-weight:700;font-size:1.25rem;color:var(--fp-text);margin-bottom:.25rem;\">\r\n                                #{reservaBean.activeCourt.name}\r\n                            </h3>\r\n                            <p class=\"fp-text-sm\" style=\"color:var(--fp-text-secondary);margin-bottom:.75rem;\">\r\n                                #{reservaBean.activeCourt.surface} ·\r\n                                <span class=\"fp-font-bold fp-text-primary\">$#{reservaBean.activeCourt.pricePerHour}/hora</span>\r\n                            </p>\r\n                            <div class=\"fp-flex fp-gap-3\" style=\"font-size:.8125rem;color:var(--fp-text-secondary);\">\r\n                                <h:panelGroup rendered=\"#{reservaBean.activeCourt.hasLighting}\" styleClass=\"fp-flex fp-items-center fp-gap-1\">\r\n                                    <span class=\"material-symbols-outlined\" style=\"font-size:1rem;\">wb_incandescent</span> Iluminación\r\n                                </h:panelGroup>\r\n                                <h:panelGroup rendered=\"#{reservaBean.activeCourt.covered}\" styleClass=\"fp-flex fp-items-center fp-gap-1\">\r\n                                    <span class=\"material-symbols-outlined\" style=\"font-size:1rem;\">roofing</span> Techada\r\n                                </h:panelGroup>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"fp-card fp-card-padded\" style=\"margin-top:1.5rem;\" id=\"scheduleWrap\">\r\n                        <div class=\"fp-flex fp-justify-between fp-items-center fp-mb-4\" style=\"flex-wrap:wrap;gap:.5rem;\">\r\n                            <h4 style=\"font-family:'DM Sans',sans-serif;font-weight:700;color:var(--fp-text);\">Horarios disponibles</h4>\r\n                            <div class=\"fp-flex fp-gap-3\" style=\"font-size:.75rem;color:var(--fp-text-secondary);\">\r\n                                <span class=\"fp-flex fp-items-center fp-gap-1\"><span class=\"fp-slot-dot fp-slot-dot-free\"></span>Disponible</span>\r\n                                <span class=\"fp-flex fp-items-center fp-gap-1\"><span class=\"fp-slot-dot fp-slot-dot-busy\"></span>Ocupado</span>\r\n                            </div>\r\n                        </div>\r\n\r\n                        <div class=\"fp-slots-grid\">\r\n                            <ui:repeat value=\"#{courtService.getSchedule(reservaBean.selectedCourtId, reservaBean.date)}\" var=\"slot\">\r\n                                <p:commandLink styleClass=\"fp-slot #{slot.available ? 'fp-slot-free' : 'fp-slot-busy'} #{reservaBean.hour == slot.hour ? 'fp-slot-selected' : ''}\"\r\n                                               action=\"#{reservaBean.setHour(slot.hour)}\"\r\n                                               disabled=\"#{!slot.available}\"\r\n                                               process=\"@this\" update=\"@form\">\r\n                                    <span class=\"material-symbols-outlined\">#{slot.available ? 'event_available' : 'event_busy'}</span>\r\n                                    <span>#{slot.hour}</span>\r\n                                </p:commandLink>\r\n                            </ui:repeat>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                <!-- ═══ COLUMNA DERECHA: detalles de reserva ═══ -->\r\n                <div class=\"fp-card fp-card-padded\">\r\n                    <span class=\"fp-eyebrow\">Detalles de Reserva</span>\r\n\r\n                    <p:messages id=\"reservaMessages\" showDetail=\"true\" closable=\"false\" globalOnly=\"true\" styleClass=\"fp-form-error\"/>\r\n\r\n                    <div class=\"fp-grid fp-grid-3\" style=\"margin-bottom:1rem;\">\r\n                        <div class=\"fp-form-group\" style=\"margin-bottom:0;\">\r\n                            <label class=\"fp-form-label\">Fecha</label>\r\n                            <h:inputText value=\"#{reservaBean.date}\" styleClass=\"fp-input\">\r\n                                <f:passThroughAttribute name=\"type\" value=\"date\"/>\r\n                                <p:ajax event=\"change\" process=\"@this\" update=\"scheduleWrap\"/>\r\n                            </h:inputText>\r\n                        </div>\r\n                        <div class=\"fp-form-group\" style=\"margin-bottom:0;\">\r\n                            <label class=\"fp-form-label\">Hora</label>\r\n                            <p:selectOneMenu value=\"#{reservaBean.hour}\" styleClass=\"fp-input\" style=\"width:100%\">\r\n                                <f:selectItem itemLabel=\"Seleccionar hora\" itemValue=\"\" noSelectionOption=\"true\"/>\r\n                                <f:selectItems value=\"#{reservaBean.availableHours}\"/>\r\n                                <p:ajax process=\"@this\" update=\"@this\"/>\r\n                            </p:selectOneMenu>\r\n                        </div>\r\n                        <div class=\"fp-form-group\" style=\"margin-bottom:0;\">\r\n                            <label class=\"fp-form-label\">Duración</label>\r\n                            <p:selectOneMenu value=\"#{reservaBean.duration}\" styleClass=\"fp-input\" style=\"width:100%\">\r\n                                <f:selectItem itemValue=\"1\" itemLabel=\"1 hora\"/>\r\n                                <f:selectItem itemValue=\"2\" itemLabel=\"2 horas\"/>\r\n                                <f:selectItem itemValue=\"3\" itemLabel=\"3 horas\"/>\r\n                                <p:ajax process=\"@this\" update=\"priceSummary\"/>\r\n                            </p:selectOneMenu>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"fp-form-group\">\r\n                        <label class=\"fp-form-label\">Número de Jugadores</label>\r\n                        <span class=\"fp-input-icon-wrapper\">\r\n                            <span class=\"material-symbols-outlined fp-input-icon\">groups</span>\r\n                            <h:inputText value=\"#{reservaBean.playerCount}\" styleClass=\"fp-input fp-input-icon-field\">\r\n                                <f:passThroughAttribute name=\"type\" value=\"number\"/>\r\n                                <f:passThroughAttribute name=\"min\" value=\"1\"/>\r\n                                <p:ajax event=\"change\" process=\"@this\" update=\"priceSummary\"/>\r\n                            </h:inputText>\r\n                        </span>\r\n                    </div>\r\n\r\n                    <div class=\"fp-grid fp-grid-2\" style=\"margin-bottom:0;\">\r\n                        <div class=\"fp-form-group\">\r\n                            <label class=\"fp-form-label\">Nombre de Contacto</label>\r\n                            <span class=\"fp-input-icon-wrapper\">\r\n                                <span class=\"material-symbols-outlined fp-input-icon\">person</span>\r\n                                <h:inputText value=\"#{reservaBean.contactName}\" styleClass=\"fp-input fp-input-icon-field\"/>\r\n                            </span>\r\n                        </div>\r\n                        <div class=\"fp-form-group\">\r\n                            <label class=\"fp-form-label\">Teléfono</label>\r\n                            <span class=\"fp-input-icon-wrapper\">\r\n                                <span class=\"material-symbols-outlined fp-input-icon\">call</span>\r\n                                <h:inputText value=\"#{reservaBean.contactPhone}\" styleClass=\"fp-input fp-input-icon-field\"/>\r\n                            </span>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"fp-price-summary\" id=\"priceSummary\" style=\"margin:1.25rem 0;\">\r\n                        <span class=\"fp-eyebrow\" style=\"margin-bottom:0;\">\r\n                            <span class=\"material-symbols-outlined\" style=\"font-size:1rem;\">receipt_long</span> Resumen de Precio\r\n                        </span>\r\n                        <div class=\"fp-flex fp-justify-between\"><span>Precio por hora</span><span>$#{reservaBean.activeCourt.pricePerHour}</span></div>\r\n                        <div class=\"fp-flex fp-justify-between\"><span>Duración</span><span>#{reservaBean.duration} hora(s)</span></div>\r\n                        <div class=\"fp-flex fp-justify-between\" style=\"border-top:1px dashed var(--fp-border);padding-top:.5rem;\">\r\n                            <span class=\"fp-font-bold\" style=\"color:var(--fp-text);\">Total</span>\r\n                            <span class=\"fp-font-bold fp-text-primary\">$#{reservaBean.totalPrice}</span>\r\n                        </div>\r\n                        <div class=\"fp-flex fp-justify-between fp-text-xs\">\r\n                            <span>Precio por jugador</span><span>$#{reservaBean.pricePerPlayer}</span>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"fp-flex fp-gap-3\">\r\n                        <p:commandButton value=\"Confirmar Reserva\" icon=\"pi pi-calendar-plus\"\r\n                                         action=\"#{reservaBean.doReserve}\"\r\n                                         process=\"@form\" update=\"@form growl\"\r\n                                         styleClass=\"fp-btn fp-btn-primary\" style=\"flex:1\"\r\n                                         oncomplete=\"if(!#{authBean.authenticated}){PF('authModal').show();}\"/>\r\n                        <h:link outcome=\"/horarios\" styleClass=\"fp-btn fp-btn-outline\">Cancelar</h:link>\r\n                    </div>\r\n                </div>\r\n\r\n            </div>\r\n        </h:panelGroup>\r\n\r\n    </ui:define>\r\n\r\n</ui:composition>
