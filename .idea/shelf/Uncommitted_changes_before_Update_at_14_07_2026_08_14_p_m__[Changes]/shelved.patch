family: 'DM Sans', sans-serif;\r\n    background-color: var(--fp-bg);\r\n    color: var(--fp-text);\r\n    -webkit-font-smoothing: antialiased;\r\n    overflow-x: hidden;\r\n    transition: background-color 0.4s ease, color 0.4s ease;\r\n}\r\n\r\n::selection { background: var(--fp-primary); color: #fff; }\r\nbody.dark ::selection { background: var(--fp-primary); color: #0A0A0A; }\r\n\r\n.material-symbols-outlined {\r\n    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\r\n    vertical-align: middle;\r\n}\r\n\r\n/* ═══ GLASS NAVIGATION ═══ */\r\n.fp-glass-nav {\r\n    position: fixed; top: 0; width: 100%; z-index: 50;\r\n    background: var(--fp-nav-bg);\r\n    backdrop-filter: blur(20px) saturate(180%);\r\n    border-bottom: 1px solid var(--fp-glass-border);\r\n    transition: all 0.3s ease;\r\n}\r\n.fp-glass-nav.scrolled { box-shadow: var(--fp-shadow); }\r\n.fp-nav-container {\r\n    max-width: 80rem; margin: 0 auto; display: flex;\r\n    align-items: center; justify-content: space-between;\r\n    height: 4rem; padding: 0 1rem;\r\n}\r\n.fp-logo-link {\r\n    display: flex; align-items: center; gap: 0.625rem;\r\n    text-decoration: none;\r\n}\r\n.fp-logo-icon {\r\n    width: 2.25rem; height: 2.25rem; border-radius: 0.75rem;\r\n    background: var(--fp-primary); display: flex;\r\n    align-items: center; justify-content: center;\r\n}\r\n.fp-logo-icon-sm { width: 2rem; height: 2rem; }\r\n.fp-logo-symbol { color: #fff; font-size: 1.25rem; }\r\nbody.dark .fp-logo-symbol { color: #0A0A0A; }\r\n.fp-logo-text {\r\n    font-family: 'DM Sans', sans-serif; font-weight: 700;\r\n    font-size: 1.25rem; color: var(--fp-primary-text);\r\n}\r\n.fp-role-badge {\r\n    font-size: 0.625rem; font-weight: 700; text-transform: uppercase;\r\n    letter-spacing: 0.05em; padding: 0.125rem 0.5rem;\r\n    border-radius: 9999px;\r\n}\r\n.fp-role-admin { background: var(--fp-accent); color: var(--fp-accent-text); }\r\n.fp-role-player { background: rgba(27, 94, 59, 0.1); color: var(--fp-primary-text); }\r\n\r\n.fp-nav-links { display: flex; gap: 0.25rem; }\r\n.fp-nav-link {\r\n    display: flex; align-items: center; gap: 0.375rem;\r\n    padding: 0.5rem 1rem; border-radius: 0.5rem;\r\n    font-size: 0.875rem; font-weight: 500;\r\n    color: var(--fp-text-secondary); text-decoration: none;\r\n    transition: all 0.25s;\r\n}\r\n.fp-nav-link:hover { color: var(--fp-text); background: var(--fp-bg-hover); }\r\n.fp-nav-link.active {\r\n    background: var(--fp-primary); color: #fff;\r\n}\r\nbody.dark .fp-nav-link.active { color: #0A0A0A; }\r\n.fp-nav-link .material-symbols-outlined { font-size: 1.125rem; }\r\n\r\n.fp-nav-actions { display: flex; align-items: center; gap: 0.75rem; }\r\n.fp-theme-toggle {\r\n    background: none; border: none; cursor: pointer;\r\n    padding: 0.5rem; border-radius: 0.75rem;\r\n    color: var(--fp-primary-text); transition: all 0.3s;\r\n}\r\n.fp-theme-toggle:hover { background: var(--fp-bg-hover); }\r\n\r\n.fp-user-menu { display: flex; align-items: center; gap: 0.75rem; }\r\n.fp-user-avatar {\r\n    width: 2rem; height: 2rem; border-radius: 50%;\r\n    background: var(--fp-primary); color: #fff;\r\n    display: flex; align-items: center; justify-content: center;\r\n}\r\n.fp-user-name {\r\n    font-size: 0.875rem; font-weight: 600;\r\n    color: var(--fp-text); display: none;\r\n}\r\n@media (min-width: 640px) { .fp-user-name { display: inline; } }\r\n\r\n/* ═══ MAIN CONTENT ═══ */\r\n.fp-main {\r\n    min-height: 100vh; padding-top: 4rem;\r\n    background: var(--fp-bg); transition: background 0.4s;\r\n}\r\n\r\n/* ═══ BUTTONS ═══ */\r\n.fp-btn {\r\n    display: inline-flex; align-items: center; gap: 0.5rem;\r\n    padding: 0.625rem 1.25rem; border-radius: 0.75rem;\r\n    font-family: 'DM Sans', sans-serif; font-weight: 600;\r\n    font-size: 0.875rem; border: none; cursor: pointer;\r\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\r\n    text-decoration: none; line-height: 1.4;\r\n}\r\n.fp-btn-sm { padding: 0.375rem 1rem; font-size: 0.8125rem; }\r\n.fp-btn-lg { padding: 0.875rem 2rem; font-size: 1rem; }\r\n.fp-btn-full { width: 100%; justify-content: center; }\r\n.fp-btn-primary {\r\n    background: var(--fp-primary); color: #fff;\r\n}\r\nbody.dark .fp-btn-primary { color: #0A0A0A; }\r\n.fp-btn-primary:hover { filter: brightness(1.1); transform: translateY(-1px); }\r\n.fp-btn-accent {\r\n    background: var(--fp-accent); color: var(--fp-accent-text);\r\n}\r\n.fp-btn-accent:hover { background: var(--fp-accent-hover); }\r\n.fp-btn-outline {\r\n    background: transparent; border: 2px solid var(--fp-border);\r\n    color: var(--fp-text-secondary);\r\n}\r\n.fp-btn-outline:hover { border-color: var(--fp-primary); color: var(--fp-primary-text); }\r\n.fp-btn-error {\r\n    background: var(--fp-error-bg); color: var(--fp-error);\r\n}\r\n.fp-btn-error:hover { background: var(--fp-error); color: #fff; }\r\n\r\n/* ═══ CARDS ═══ */\r\n.fp-card {\r\n    background: var(--fp-bg-card); border: 1px solid var(--fp-border-light);\r\n    border-radius: 1rem; transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);\r\n}\r\n.fp-card:hover { border-color: rgba(27, 94, 59, 0.2); box-shadow: 0 4px 20px rgba(0,0,0,0.06); }\r\nbody.dark .fp-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.3); }\r\n.fp-card-padded { padding: 1.5rem; }\r\n\r\n/* ═══ CHIPS ═══ */\r\n.fp-chip {\r\n    display: inline-flex; align-items: center; gap: 0.375rem;\r\n    padding: 0.375rem 0.875rem; border-radius: 9999px;\r\n    font-size: 0.8125rem; font-weight: 600; border: 1px solid var(--fp-border);\r\n    color: var(--fp-text-secondary); background: transparent;\r\n    transition: all 0.3s; cursor: pointer;\r\n}\r\n.fp-chip:hover { border-color: var(--fp-primary); }\r\n.fp-chip-active, .fp-chip-primary {\r\n    background: var(--fp-primary); color: #fff; border-color: var(--fp-primary);\r\n}\r\nbody.dark .fp-chip-active, body.dark .fp-chip-primary { color: #0A0A0A; }\r\n\r\n/* ═══ FORMS ═══ */\r\n.fp-input {\r\n    width: 100%; padding: 0.625rem 1rem; border-radius: 0.75rem;\r\n    border: 1px solid var(--fp-border); background: var(--fp-bg-card);\r\n    color: var(--fp-text); font-family: 'DM Sans', sans-serif;\r\n    font-size: 0.875rem; transition: all 0.3s; outline: none;\r\n}\r\n.fp-input:focus { border-color: var(--fp-primary); box-shadow: 0 0 0 3px rgba(27, 94, 59, 0.1); }\r\nbody.dark .fp-input:focus { box-shadow: 0 0 0 3px rgba(183, 205, 113, 0.1); }\r\n.fp-input::placeholder { color: var(--fp-text-muted); }\r\n\r\n.fp-input-icon-wrapper { position: relative; }\r\n.fp-input-icon {\r\n    position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%);\r\n    color: var(--fp-text-muted); font-size: 1.125rem;\r\n}\r\n.fp-input-icon-field { padding-left: 2.5rem !important; }\r\n\r\n.fp-form-group { margin-bottom: 1rem; }\r\n.fp-form-label {\r\n    display: block; font-size: 0.6875rem; font-weight: 700;\r\n    text-transform: uppercase; letter-spacing: 0.06em;\r\n    color: var(--fp-text-muted); margin-bottom: 0.5rem;\r\n}\r\n\r\n/* ═══ MODAL ═══ */\r\n.fp-modal-overlay {\r\n    position: fixed; inset: 0; z-index: 100;\r\n    display: flex; align-items: center; justify-content: center;\r\n    padding: 1rem;\r\n}\r\n.fp-modal-backdrop {\r\n    position: absolute; inset: 0;\r\n    background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(8px);\r\n}\r\n.fp-modal {\r\n    position: relative; background: var(--fp-bg-card);\r\n    border: 1px solid var(--fp-border); border-radius: 1.5rem;\r\n    width: 100%; max-width: 28rem; padding: 2rem;\r\n    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);\r\n    animation: fp-scale-in 0.3s ease-out;\r\n}\r\n.fp-modal-close {\r\n    position: absolute; top: 1rem; right: 1rem;\r\n    width: 2.25rem; height: 2.25rem; border-radius: 0.75rem;\r\n    border: none; background: var(--fp-bg-hover); color: var(--fp-text-muted);\r\n    cursor: pointer; display: flex; align-items: center; justify-content: center;\r\n    transition: all 0.3s;\r\n}\r\n.fp-modal-close:hover { color: var(--fp-text); }\r\n.fp-modal-header { text-align: center; margin-bottom: 2rem; }\r\n.fp-modal-icon {\r\n    width: 3.5rem; height: 3.5rem; border-radius: 1.25rem;\r\n    background: var(--fp-primary); color: #fff;\r\n    display: flex; align-items: center; justify-content: center;\r\n    margin: 0 auto 1rem;\r\n}\r\nbody.dark .fp-modal-icon { color: #0A0A0A; }\r\n.fp-modal-icon .material-symbols-outlined { font-size: 1.5rem; }\r\n.fp-modal-title {\r\n    font-family: 'DM Sans', sans-serif; font-weight: 700;\r\n    font-size: 1.5rem; color: var(--fp-text); margin-bottom: 0.25rem;\r\n}\r\n.fp-modal-subtitle { color: var(--fp-text-secondary); font-size: 0.875rem; }\r\n.fp-modal-form { display: flex; flex-direction: column; }\r\n.fp-form-switch {\r\n    text-align: center; margin-top: 1rem; font-size: 0.8125rem;\r\n    color: var(--fp-text-secondary);\r\n}\r\n.fp-form-switch a { color: var(--fp-primary-text); font-weight: 600; text-decoration: none; }\r\n.fp-demo-hint {\r\n    text-align: center; margin-top: 0.75rem;\r\n    font-size: 0.6875rem; color: var(--fp-text-muted);\r\n}\r\n.fp-radio-group .ui-radiobutton-label { color: var(--fp-text) !important; }\r\n\r\n/* ═══ HERO SECTION ═══ */\r\n.fp-hero {\r\n    position: relative; height: 90vh; min-height: 600px;\r\n    display: flex; align-items: center; justify-content: center;\r\n    overflow: hidden;\r\n}\r\n.fp-hero-bg {\r\n    position: absolute; inset: 0; z-index: 0;\r\n}\r\n.fp-hero-bg img {\r\n    width: 100%; height: 100%; object-fit: cover;\r\n    transform: scale(1.05);\r\n}\r\n.fp-hero-overlay {\r\n    position: absolute; inset: 0;\r\n    background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0) 40%, rgba(0,0,0,0.7) 100%);\r\n}\r\n.fp-hero-content {\r\n    position: relative; z-index: 10; text-align: center;\r\n    max-width: 48rem; padding: 0 1rem;\r\n}\r\n\r\n/* ═══ STATS ═══ */\r\n.fp-stats-bar {\r\n    background: var(--fp-bg-elevated); border-top: 1px solid var(--fp-border-light);\r\n    border-bottom: 1px solid var(--fp-border-light);\r\n    padding: 2.5rem 1rem; transition: all 0.4s;\r\n}\r\n.fp-stats-grid {\r\n    max-width: 80rem; margin: 0 auto;\r\n    display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem;\r\n}\r\n.fp-stat-value {\r\n    font-family: 'DM Sans', sans-serif; font-weight: 700;\r\n    font-size: 1.875rem; color: var(--fp-primary-text); margin-bottom: 0.25rem;\r\n}\r\n.fp-stat-label { font-size: 0.875rem; color: var(--fp-text-muted); font-weight: 500; }\r\n\r\n/* ═══ ZONE CARDS ═══ */\r\n.fp-zone-card-header {\r\n    padding: 1rem 1.5rem; display: flex;\r\n    align-items: center; justify-content: space-between;\r\n    color: #fff;\r\n}\r\n.fp-zone-norte { background: linear-gradient(to right, rgba(22, 163, 74, 0.8), rgba(21, 128, 61, 0.6)); }\r\n.fp-zone-sur { background: linear-gradient(to right, rgba(217, 119, 6, 0.8), rgba(180, 83, 9, 0.6)); }\r\n.fp-zone-este { background: linear-gradient(to right, rgba(37, 99, 235, 0.8), rgba(29, 78, 216, 0.6)); }\r\n.fp-zone-oeste { background: linear-gradient(to right, rgba(147, 51, 234, 0.8), rgba(126, 34, 206, 0.6)); }\r\n.fp-zone-centro { background: linear-gradient(to right, rgba(225, 29, 72, 0.8), rgba(190, 18, 60, 0.6)); }\r\n\r\n/* ═══ FOOTER ═══ */\r\n.fp-footer {\r\n    border-top: 1px solid var(--fp-border);\r\n    background: var(--fp-bg-elevated); transition: all 0.4s;\r\n}\r\n.fp-footer-container { max-width: 80rem; margin: 0 auto; padding: 3rem 1rem; }\r\n.fp-footer-grid {\r\n    display: grid; grid-template-columns: 1fr; gap: 2rem;\r\n}\r\n@media (min-width: 768px) { .fp-footer-grid { grid-template-columns: repeat(4, 1fr); } }\r\n.fp-footer-brand { margin-bottom: 1rem; }\r\n.fp-footer-desc {\r\n    font-size: 0.875rem; color: var(--fp-text-muted);\r\n    line-height: 1.625; margin-top: 1rem;\r\n}\r\n.fp-footer-heading {\r\n    font-family: 'DM Sans', sans-serif; font-weight: 600;\r\n    font-size: 0.8125rem; text-transform: uppercase;\r\n    letter-spacing: 0.06em; color: var(--fp-text);\r\n    margin-bottom: 1rem;\r\n}\r\n.fp-footer-list { list-style: none; padding: 0; }\r\n.fp-footer-list li { margin-bottom: 0.625rem; }\r\n.fp-footer-link {\r\n    font-size: 0.875rem; color: var(--fp-text-secondary);\r\n    text-decoration: none; transition: color 0.2s;\r\n}\r\n.fp-footer-link:hover { color: var(--fp-primary-text); }\r\n.fp-footer-contact {\r\n    display: flex; align-items: center; gap: 0.5rem;\r\n    font-size: 0.875rem; color: var(--fp-text-secondary);\r\n}\r\n.fp-footer-contact .material-symbols-outlined {\r\n    font-size: 1.125rem; color: var(--fp-primary-text);\r\n}\r\n.fp-footer-bottom {\r\n    margin-top: 2.5rem; padding-top: 1.5rem;\r\n    border-top: 1px solid var(--fp-border);\r\n    display: flex; flex-direction: column; gap: 0.75rem;\r\n    align-items: center;\r\n}\r\n@media (min-width: 640px) {\r\n    .fp-footer-bottom { flex-direction: row; justify-content: space-between; }\r\n}\r\n.fp-footer-bottom p { font-size: 0.75rem; color: var(--fp-text-muted); }\r\n.fp-footer-bottom-links { display: flex; gap: 1rem; }\r\n.fp-footer-bottom-links a {\r\n    font-size: 0.75rem; color: var(--fp-text-muted);\r\n    text-decoration: none;\r\n}\r\n.fp-footer-bottom-links a:hover { color: var(--fp-primary-text); }\r\n\r\n/* ═══ SECTION UTILITIES ═══ */\r\n.fp-section { padding: 5rem 1rem; max-width: 80rem; margin: 0 auto; }\r\n.fp-section-title {\r\n    font-family: 'DM Sans', sans-serif; font-weight: 700;\r\n    font-size: 1.875rem; color: var(--fp-text); margin-bottom: 0.75rem;\r\n    letter-spacing: -0.01em;\r\n}\r\n.fp-section-subtitle { color: var(--fp-text-secondary); max-width: 40rem; margin: 0 auto; }\r\n.fp-text-center { text-align: center; }\r\n.fp-text-primary { color: var(--fp-primary-text); }\r\n\r\n/* ═══ GRID ═══ */\r\n.fp-grid { display: grid; gap: 1.25rem; }\r\n.fp-grid-2 { grid-template-columns: 1fr; }\r\n.fp-grid-3 { grid-template-columns: 1fr; }\r\n.fp-grid-4 { grid-template-columns: 1fr; }\r\n@media (min-width: 768px) {\r\n    .fp-grid-2 { grid-template-columns: repeat(2, 1fr); }\r\n    .fp-grid-3 { grid-template-columns: repeat(3, 1fr); }\r\n    .fp-grid-4 { grid-template-columns: repeat(4, 1fr); }\r\n}\r\n\r\n/* ═══ ANIMATIONS ═══ */\r\n@keyframes fp-scale-in {\r\n    from { opacity: 0; transform: scale(0.95); }\r\n    to { opacity: 1; transform: scale(1); }\r\n}\r\n@keyframes fp-fade-in-up {\r\n    from { opacity: 0; transform: translateY(20px); }\r\n    to { opacity: 1; transform: translateY(0); }\r\n}\r\n.fp-animate-fade-in { animation: fp-fade-in-up 0.6s ease-out forwards; }\r\n\r\n/* ═══ PRIMEFACES OVERRIDES ═══ */\r\n.ui-growl { position: fixed !important; top: 5rem !important; right: 1rem !important; z-index: 200 !important; }\r\n.ui-growl-message { background: var(--fp-bg-card) !important; border: 1px solid var(--fp-border) !important; border-radius: 0.75rem !important; }\r\n.ui-growl-message-text { color: var(--fp-text) !important; }\r\n\r\n/* PrimeFaces TabView override for admin */\r\n.ui-tabview { background: transparent !important; }\r\n.ui-tabview .ui-tabview-nav { border: none !important; background: transparent !important; gap: 0.5rem !important; padding: 0 !important; border-bottom: 1px solid var(--fp-border-light) !important; }\r\n.ui-tabview .ui-tabview-nav li { border: none !important; border-radius: 0.75rem 0.75rem 0 0 !important; }\r\n.ui-tabview .ui-tabview-nav li a { color: var(--fp-text-secondary) !important; font-weight: 600 !important; padding: 0.75rem 1.25rem !important; }\r\n.ui-tabview .ui-tabview-nav li.ui-state-active { background: var(--fp-primary) !important; }\r\n.ui-tabview .ui-tabview-nav li.ui-state-active a { color: #fff !important; }\r\nbody.dark .ui-tabview .ui-tabview-nav li.ui-state-active a { color: #0A0A0A !important; }\r\n.ui-tabview .ui-tabview-panels { background: transparent !important; border: none !important; padding: 0 !important; margin-top: 0.5rem !important; }\r\n\r\n/* PrimeFaces DataTable override */\r\n.ui-datatable { background: transparent !important; }\r\n.ui-datatable .ui-datatable-header { background: var(--fp-bg-elevated) !important; border: 1px solid var(--fp-border-light) !important; border-radius: 0.75rem 0.75rem 0 0 !important; }\r\n.ui-datatable .ui-datatable-thead th { background: var(--fp-bg-elevated) !important; color: var(--fp-text-muted) !important; font-size: 0.6875rem !important; font-weight: 700 !important; text-transform: uppercase !important; letter-spacing: 0.06em !important; border-bottom: 1px solid var(--fp-border-light) !important; }\r\n.ui-datatable .ui-datatable-tbody td { border-bottom: 1px solid var(--fp-border-light) !important; color: var(--fp-text) !important; }\r\n.ui-datatable .ui-datatable-tbody tr:hover { background: var(--fp-bg-hover) !important; }\r\n\r\n/* PrimeFaces SelectOneRadio override */\r\n.ui-selectoneradio .ui-radiobutton-box { border: 2px solid var(--fp-border) !important; }\r\n.ui-selectoneradio .ui-radiobutton-box.ui-state-active { border-color: var(--fp-primary) !important; background: var(--fp-primary) !important; }\r\n\r\n/* Status chips */\r\n.fp-status-upcoming { background: rgba(27, 94, 59, 0.1); color: var(--fp-primary-text); }\r\n.fp-status-completed { background: var(--fp-border-light); color: var(--fp-text-secondary); }\r\n.fp-status-cancelled { background: rgba(220, 38, 38, 0.1); color: var(--fp-error); }\r\nbody.dark .fp-status-upcoming { background: rgba(183, 205, 113, 0.1); }\r\n\r\n/* ═══ ADMIN SPECIFIC ═══ */\r\n.fp-admin-tab {\r\n    display: flex; align-items: center; gap: 0.5rem;\r\n    padding: 0.75rem 1.25rem; font-size: 0.875rem;\r\n    font-weight: 600; border: none; cursor: pointer;\r\n    border-radius: 0.75rem 0.75rem 0 0;\r\n    color: var(--fp-text-secondary); background: transparent;\r\n    transition: all 0.3s; white-space: nowrap;\r\n}\r\n.fp-admin-tab:hover { color: var(--fp-text); background: var(--fp-bg-hover); }\r\n.fp-admin-tab.active {\r\n    background: var(--fp-primary); color: #fff;\r\n}\r\nbody.dark .fp-admin-tab.active { color: #0A0A0A; }\r\n.fp-admin-tab .material-symbols-outlined { font-size: 1.125rem; }\r\n\r\n/* Court card with image */\r\n.fp-court-card {\r\n    overflow: hidden; border-radius: 1rem;\r\n    transition: all 0.35s;\r\n}\r\n.fp-court-card:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,0,0,0.1); }\r\n.fp-court-img {\r\n    width: 100%; height: 10rem; object-fit: cover;\r\n    background: var(--fp-bg-elevated);\r\n}\r\n.fp-court-card-body { padding: 1rem; }\r\n.fp-court-price {\r\n    font-family: 'DM Sans', sans-serif; font-weight: 700;\r\n    font-size: 1.25rem; color: var(--fp-primary-text);\r\n}\r\n\r\n/* Map embed */\r\n.fp-map-container {\r\n    width: 100%; height: 15rem; border-radius: 0.75rem;\r\n    overflow: hidden; border: 1px solid var(--fp-border-light);\r\n}\r\n.fp-map-container iframe { width: 100%; height: 100%; border: 0; }\r\n\r\n/* ═══ RESPONSIVE ═══ */\r\n@media (max-width: 768px) {\r\n    .fp-nav-links { display: none; }\r\n    .fp-stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }\r\n    .fp-hero { height: 80vh; min-height: 500px; }\r\n}\r\n\r\n/* ═══ UTILITIES ═══ */\r\n.fp-flex { display: flex; }\r\n.fp-flex-col { flex-direction: column; }\r\n.fp-items-center { align-items: center; }\r\n.fp-justify-between { justify-content: space-between; }\r\n.fp-gap-1 { gap: 0.25rem; }\r\n.fp-gap-2 { gap: 0.5rem; }\r\n.fp-gap-3 { gap: 0.75rem; }\r\n.fp-gap-4 { gap: 1rem; }\r\n.fp-mb-2 { margin-bottom: 0.5rem; }\r\n.fp-mb-4 { margin-bottom: 1rem; }\r\n.fp-mb-6 { margin-bottom: 1.5rem; }\r\n.fp-mb-8 { margin-bottom: 2rem; }\r\n.fp-mt-4 { margin-top: 1rem; }\r\n.fp-p-4 { padding: 1rem; }\r\n.fp-p-6 { padding: 1.5rem; }\r\n.fp-text-sm { font-size: 0.875rem; }\r\n.fp-text-xs { font-size: 0.75rem; }\r\n.fp-font-bold { font-weight: 700; }\r\n.fp-w-full { width: 100%; }\r\n
